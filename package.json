{
  "name": "flowboard",
  "version": "1.0.0",
  "description": "Personal AI-powered Kanban board",
  "author": {
    "name": "Flowboard",
    "email": "support@flowboard.app"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.flowboard.app",
    "productName": "Flowboard",
    "copyright": "Copyright © 2025 Flowboard",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "publisherName": "Flowboard"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "Flowboard",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Flowboard",
      "deleteAppDataOnUninstall": false,
      "license": "LICENSE.txt"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "assets/**",
      "!assets/icon.png",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/.bin"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
