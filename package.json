{
  "name": "flowboard",
  "version": "1.0.0",
  "description": "Personal AI-powered Kanban board",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.flowboard.app",
    "productName": "Flowboard",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "shortcutName": "Flowboard"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "assets/**"
    ]
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "electron-winstaller@5.4.0": true
  }
}
